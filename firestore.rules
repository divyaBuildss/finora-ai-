rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document (by document ID)
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 1. Users collection: Only owner can read/write their profile (doc ID matches UID)
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // Helper functions for user-owned resource checks
    function belongsToUser() {
      return isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    function belongsToUserOnWrite() {
      return isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // 2. Apply rules to all other transactional and configuration collections
    
    match /expenses/{expenseId} {
      allow read, delete: if belongsToUser();
      allow create: if belongsToUserOnWrite();
      allow update: if belongsToUser() && belongsToUserOnWrite();
    }
    
    match /budgets/{budgetId} {
      allow read, delete: if belongsToUser();
      allow create: if belongsToUserOnWrite();
      allow update: if belongsToUser() && belongsToUserOnWrite();
    }
    
    match /goals/{goalId} {
      allow read, delete: if belongsToUser();
      allow create: if belongsToUserOnWrite();
      allow update: if belongsToUser() && belongsToUserOnWrite();
    }
    
    match /investments/{investmentId} {
      allow read, delete: if belongsToUser();
      allow create: if belongsToUserOnWrite();
      allow update: if belongsToUser() && belongsToUserOnWrite();
    }
    
    match /chatHistory/{chatId} {
      allow read, delete: if belongsToUser();
      allow create: if belongsToUserOnWrite();
      allow update: if belongsToUser() && belongsToUserOnWrite();
    }

    match /notifications/{notificationId} {
      allow read, delete: if belongsToUser();
      allow create: if belongsToUserOnWrite();
      allow update: if belongsToUser() && belongsToUserOnWrite();
    }
    
    // Deny all other public/unmapped requests by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
