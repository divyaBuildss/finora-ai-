# Finora AI - Firebase Configuration Environment Variables Template
# Copy this file to '.env' and populate with your institutional credentials.

VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=1:your_messaging_sender_id:web:your_app_hash_id

# Gemini API Configurations (Optional - advisor chat fallback triggers if not configured)
VITE_GEMINI_API_KEY=your_google_gemini_api_key_here
